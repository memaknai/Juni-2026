<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Kinerja Keuangan - Desember 2025</title>
    <!-- CDN Font Awesome agar Ikon Muncul -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        *{margin:0; padding:0; box-sizing:border-box; }
        body{font-family:'Segoe UI',sans-serif; background: radial-gradient(circle at top right, rgba(10,147,150,.12), transparent 35%), #f5f7fa; color:#1f2937; }
        
        /* HEADER */
        .header{background:linear-gradient(135deg, #004e64 0%, #006d77 50%, #0a9396 100% ); color:white; text-align:center; padding:50px 20px 30px 20px; position:relative; overflow:hidden; animation:fadeDown .8s ease; }
        .header::before{content:""; position:absolute; top:0; left:-100%; width:50%; height:100%; background:linear-gradient(90deg, transparent, rgba(255,255,255,.15), transparent ); animation:shine 5s infinite; }
        .header h1{font-size:40px; margin-bottom:8px; position:relative; z-index:2; }
        .header p{font-size:18px; position:relative; z-index:2; opacity:0.9; }

        /* NAVIGASI ARSIP BULANAN */
        .archive-container {
            max-width: 1300px;
            margin: 30px auto 10px auto;
            padding: 0 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }
        .archive-label {
            font-size: 14px;
            font-weight: 600;
            color: #4b5563;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .archive-list {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }
        .archive-btn {
            text-decoration: none;
            background: #e5e7eb;
            color: #374151;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 500;
            transition: all 0.3s ease;
        }
        .archive-btn:hover {
            background: #006d77;
            color: white;
        }
        .archive-btn.active {
            background: #004e64;
            color: white;
            font-weight: 600;
            box-shadow: 0 4px 10px rgba(0, 78, 100, 0.2);
        }
        
        /* CONTAINER */
        .container{max-width:1300px; margin:20px auto 40px auto; padding:0 20px; }
        
        /* GRID */
        .grid{display:grid; grid-template-columns:repeat(auto-fit,minmax(320px,1fr)); gap:24px; }
        
        /* CARD */
        .card{background:white; border-radius:20px; padding:28px; text-decoration:none; color:inherit; border-top:5px solid #0a9396; box-shadow:0 10px 25px rgba(0,0,0,.08); transition: transform .35s ease, box-shadow .35s ease; opacity:0; animation:fadeUp .6s ease forwards; }
        .card:nth-child(1){animation-delay:.1s;}
        .card:hover{transform: translateY(-6px) scale(1.02); box-shadow: 0 20px 35px rgba(0,109,119,.18); }
        
        .icon{width:70px; height:70px; border-radius:18px; background:#eef8f8; display:flex; align-items:center; justify-content:center; color:#006d77; font-size:30px; margin-bottom:18px; transition:all .3s ease; }
        .card:hover .icon{background:#006d77; color:white; transform:scale(1.1); }
        .title{font-size:22px; font-weight:700; color:#003049; margin-bottom:8px; }
        .desc{color:#6b7280; line-height:1.6; font-size:15px; }
        .footer{text-align:center; margin-top:45px; color:#6b7280; font-size:13px; }
        
        /* ANIMATION */
        @keyframes fadeUp{from{opacity:0; transform:translateY(35px); } to{opacity:1; transform:translateY(0); } }
        @keyframes fadeDown{from{opacity:0; transform:translateY(-25px); } to{opacity:1; transform:translateY(0); } }
        @keyframes shine{from{left:-100%;} to{left:200%;} }
        
        /* RESPONSIVE DESIGN */
        @media (max-width: 992px){.header h1{font-size:32px; } .header p{font-size:16px; } }
        @media (max-width: 768px){
            .header{padding:40px 20px 25px 20px; } 
            .header h1{font-size:26px; } 
            .header p{font-size:14px; } 
            .archive-container{margin-top:20px; justify-content:center;}
            .grid{grid-template-columns:1fr; } 
            .card{padding:22px; } 
            .title{font-size:20px; } 
            .icon{width:60px; height:60px; font-size:26px; } 
        }
    </style>
</head>
<body>
    <!-- HEADER -->
    <div class="header">
        <h1>Dashboard Kinerja Keuangan</h1>
        <p>Periode: 31 Desember 2025</p>
    </div>

    <!-- STRUKTUR NAVIGASI ARSIP -->
    <div class="archive-container">
        <div class="archive-label">
            <i class="fa-regular fa-calendar-days"></i> Pilih Periode:
        </div>
        <div class="archive-list">
            <!-- Jalur mundur ke root folder (Halaman Juni) -->
            <a href="../../index.html" class="archive-btn">Juni 2026</a>
            <!-- Tautan tetap berada di file ini -->
            <a href="index.html" class="archive-btn active">Desember 2025</a>
        </div>
    </div>

    <!-- MAIN DASHBOARD -->
    <div class="container">
        <div class="grid">
            <!-- Menambahkan Cache Buster (?v=0326) untuk mengunci agar browser tidak salah memuat cache file lama -->
            <a href="laporan-0326.pdf?v=0326" class="card">
                <div class="icon">
                    <i class="fa-solid fa-file-pdf"></i>
                </div>
                <div class="title">Laporan Bulanan</div>
                <div class="desc">Laporan Bulanan Kinerja Keuangan periode Desember 2025.</div>
            </a>
        </div>
        <div class="footer">
            Dashboard Kinerja Keuangan • UID Jawa Tengah
        </div>
    </div>
</body>
</html>
